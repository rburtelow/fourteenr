{
    "extends": [
        "config:recommended"
    ],
    "platformAutomerge": true,
    "schedule": [
        "before 6am on Monday"
    ],
    "packageRules": [
        {
            "description": "Group and automatically merge minor and patch-level updates weekly",
            "matchUpdateTypes": [
                "minor",
                "patch",
                "digest",
                "lockFileMaintenance"
            ],
            "automerge": true,
            "automergeType": "pr",
            "groupName": "all non-major dependencies"
        }
    ]
}
