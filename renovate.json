{
  "extends": [
    "config:recommended",
    "schedule:automergeDaily"
  ],
  "timezone": "America/Chicago",
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "description": "Automatically merge minor and patch-level updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}